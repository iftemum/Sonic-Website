---
import { Image } from 'astro:assets';
import sonicLogo from '../assets/sonic_logo.webp';
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="Sonic Window Cleaning — Home">
        <Image
          src={sonicLogo}
          alt="Sonic Window Cleaning"
          width={48}
          height={48}
          loading="lazy"
        />
      </a>
      <p class="footer__tagline">
        Professional exterior cleaning across Saskatoon and 25+ surrounding
        communities. Locally owned. Fully insured.
      </p>
      <div class="footer__socials">
        <a
          href="https://www.facebook.com/profile.php?id=61561978381555"
          class="footer__social"
          aria-label="Sonic Window Cleaning on Facebook"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a
          href="https://www.instagram.com/soniiicwindowcleaning/"
          class="footer__social"
          aria-label="Sonic Window Cleaning on Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
      </div>
    </div>

    <nav class="footer__nav" aria-label="Footer navigation">
      <div class="footer__col">
        <h3 class="footer__heading">Services</h3>
        <ul>
          <li><a href="#services">Window cleaning</a></li>
          <li><a href="#services">Gutter cleaning</a></li>
          <li><a href="#services">Siding cleaning</a></li>
          <li><a href="#services">Pressure washing</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__heading">Company</h3>
        <ul>
          <li><a href="#about">How it works</a></li>
          <li><a href="#reviews">Reviews</a></li>
          <li><a href="#service-area">Service area</a></li>
          <li><a href="#faq">FAQ</a></li>
          <li><a href="#quote">Get a quote</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__heading">Contact</h3>
        <ul class="footer__contact-list">
          <li>
            <a href="mailto:Soniiicboys@gmail.com">Soniiicboys@gmail.com</a>
          </li>
          <li>
            <a href="tel:+13063817113">306-381-7113</a>
          </li>
          <li class="footer__location">Saskatoon, SK</li>
        </ul>
      </div>
    </nav>
  </div>

  <div class="footer__bottom">
    <p class="footer__copy">
      &copy; 2026 Sonic Window Cleaning. All rights reserved.
    </p>
    <p class="footer__made">
      <a href="/privacy-policy" class="footer__privacy">Privacy Policy</a>
      <span aria-hidden="true">·</span>
      Made with care in Saskatchewan.
    </p>
  </div>
</footer>

<style>
  .footer {
    background: #080f28;
    color: rgba(255, 255, 255, 0.7);
    font-family:
      'Inter',
      ui-sans-serif,
      system-ui,
      -apple-system,
      sans-serif;
    padding-top: clamp(3rem, 6vw, 5rem);
  }

  .footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem) clamp(2.5rem, 4vw, 3.5rem);
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 2fr);
    gap: clamp(2rem, 5vw, 4rem);
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
  }

  .footer__logo :global(img) {
    height: 48px;
    width: auto;
    border-radius: 8px;
    object-fit: contain;
  }

  .footer__tagline {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.55);
    max-width: 28ch;
  }

  .footer__socials {
    display: flex;
    gap: 0.75rem;
  }

  .footer__social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    transition:
      background-color 160ms ease,
      color 160ms ease,
      border-color 160ms ease;
  }

  .footer__social:hover,
  .footer__social:focus-visible {
    background: rgba(255, 90, 71, 0.15);
    color: #ff5a47;
    border-color: rgba(255, 90, 71, 0.3);
  }

  .footer__nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer__heading {
    margin: 0 0 1.25rem;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.4);
  }

  .footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__col a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 160ms ease;
  }

  .footer__col a:hover,
  .footer__col a:focus-visible {
    color: #fff;
  }

  .footer__contact-list li:last-child {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .footer__location {
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85) !important;
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.5rem clamp(1.5rem, 5vw, 4rem);
    max-width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer__copy,
  .footer__made {
    margin: 0;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.35);
    font-family: 'Courier New', Courier, monospace;
    letter-spacing: 0.02em;
  }

  .footer__made {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .footer__privacy {
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 160ms ease;
  }

  .footer__privacy:hover,
  .footer__privacy:focus-visible {
    color: rgba(255, 255, 255, 0.75);
  }

  @media (max-width: 900px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }

    .footer__nav {
      grid-template-columns: repeat(3, 1fr);
    }

    .footer__tagline {
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
    .footer__nav {
      grid-template-columns: 1fr 1fr;
    }

    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
