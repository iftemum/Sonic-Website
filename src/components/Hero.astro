---
import { Image } from 'astro:assets';
import sonicLogo from '../assets/sonic_logo.webp';

const VIDEO_URL =
  'https://pub-bb295725be3b4a64b076d16af5179956.r2.dev/Sonic_compressed_assets/Play_at_launch1.mp4';
---

<section class="hero" aria-label="Sonic Window Cleaning">
  <video
    class="hero__video"
    src={VIDEO_URL}
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    aria-hidden="true"
  ></video>
  <div class="hero__overlay" aria-hidden="true"></div>

  <header class="hero__header">
    <a href="/" class="hero__logo" aria-label="Sonic Window Cleaning — Home">
      <Image
        src={sonicLogo}
        alt="Sonic Window Cleaning"
        width={56}
        height={56}
        loading="eager"
        densities={[1, 2]}
      />
    </a>
    <nav class="hero__nav" aria-label="Primary">
      <ul>
        <li><a href="#services">Services</a></li>
        <li><a href="#work">Work</a></li>
        <li><a href="#service-area">Service area</a></li>
        <li><a href="#reviews">Reviews</a></li>
      </ul>
    </nav>
  </header>

  <div class="hero__content">
    <p class="hero__eyebrow">
      <span class="hero__dot" aria-hidden="true"></span>
      Saskatoon · Est. 2020 · 250+ Homes &amp; Counting
    </p>

    <h1 class="hero__title">
      <span class="hero__title-line">Crystal</span>
      <span class="hero__title-line">
        <span class="hero__title--accent">Clear</span> Exteriors.
      </span>
    </h1>

    <p class="hero__subtitle">
      Professional window, gutter, siding and pressure-washing across Saskatoon
      and 25+ surrounding communities. Fast quotes. Spotless finish. Locally
      owned.
    </p>

    <div class="hero__cta">
      <a href="#quote" class="btn btn--primary">
        Get a free quote
        <span class="btn__icon" aria-hidden="true">→</span>
      </a>
      <a href="#work" class="btn btn--ghost">
        Watch our work
        <span class="btn__icon" aria-hidden="true">▶</span>
      </a>
    </div>
  </div>

  <ul class="hero__services" aria-label="Service categories">
    <li>Windows</li>
    <li>Gutters</li>
    <li>Siding</li>
    <li>Driveways</li>
  </ul>

  <div class="hero__scroll" aria-hidden="true">
    <span>Scroll</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: 100vh;
    width: 100%;
    overflow: hidden;
    color: #fff;
    font-family:
      'Inter',
      ui-sans-serif,
      system-ui,
      -apple-system,
      'Segoe UI',
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    background: #0b1230;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(
        180deg,
        rgba(11, 18, 48, 0.92) 0%,
        rgba(11, 18, 48, 0.55) 30%,
        rgba(11, 18, 48, 0.55) 60%,
        rgba(11, 18, 48, 0.85) 100%
      ),
      linear-gradient(
        90deg,
        rgba(11, 18, 48, 0.7) 0%,
        rgba(11, 18, 48, 0.25) 50%,
        rgba(11, 18, 48, 0.6) 100%
      );
  }

  /* Header / nav */
  .hero__header {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem clamp(1.5rem, 5vw, 4rem);
    background: rgba(11, 18, 48, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .hero__logo {
    display: inline-flex;
    align-items: center;
  }

  .hero__logo :global(img) {
    height: clamp(40px, 4.2vw, 56px);
    width: auto;
    display: block;
    border-radius: 8px;
    object-fit: contain;
  }

  .hero__nav ul {
    display: flex;
    gap: clamp(1.25rem, 3vw, 2.75rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hero__nav a {
    color: #fff;
    text-decoration: none;
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: color 160ms ease;
  }

  .hero__nav a:hover,
  .hero__nav a:focus-visible {
    color: #ff4d3d;
  }

  /* Content */
  .hero__content {
    position: relative;
    max-width: clamp(320px, 65vw, 1100px);
    padding: clamp(2rem, 8vh, 6rem) clamp(1.5rem, 5vw, 4rem) 0;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 1.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }

  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #ff4d3d;
    box-shadow: 0 0 12px rgba(255, 77, 61, 0.8);
  }

  .hero__title {
    margin: 0 0 1.75rem;
    font-size: clamp(3.25rem, 11vw, 9.5rem);
    line-height: 0.92;
    font-weight: 800;
    letter-spacing: -0.035em;
    text-transform: none;
  }

  .hero__title-line {
    display: block;
  }

  .hero__title-line:nth-child(2) {
    background: linear-gradient(
      180deg,
      #ffffff 30%,
      rgba(255, 255, 255, 0.55) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero__title--accent {
    background: linear-gradient(180deg, #ff5a47 0%, #d6321f 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero__subtitle {
    max-width: 38rem;
    margin: 0 0 2.25rem;
    font-size: clamp(1rem, 1.25vw, 1.15rem);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.88);
  }

  /* Buttons */
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.75rem;
    border-radius: 999px;
    font-size: 1.05rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      transform 160ms ease,
      background-color 160ms ease,
      box-shadow 160ms ease;
    cursor: pointer;
    border: 0;
  }

  .btn--primary {
    background: linear-gradient(180deg, #ff5a47 0%, #e83a26 100%);
    color: #fff;
    box-shadow: 0 10px 30px -10px rgba(232, 58, 38, 0.65);
  }

  .btn--primary:hover,
  .btn--primary:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 14px 36px -10px rgba(232, 58, 38, 0.8);
  }

  .btn--ghost {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .btn--ghost:hover,
  .btn--ghost:focus-visible {
    background: rgba(255, 255, 255, 0.18);
    transform: translateY(-2px);
  }

  /* Side service list */
  .hero__services {
    position: absolute;
    right: clamp(1.5rem, 5vw, 4rem);
    top: 50%;
    transform: translateY(-50%);
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: right;
    pointer-events: none;
  }

  .hero__services li {
    position: relative;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    padding-right: 3.5rem;
  }

  .hero__services li::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    width: 2.5rem;
    height: 1px;
    background: rgba(255, 255, 255, 0.4);
  }

  /* Scroll cue */
  .hero__scroll {
    position: absolute;
    left: 50%;
    bottom: 2rem;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.7);
  }

  .hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.6),
      rgba(255, 255, 255, 0)
    );
    animation: scrollPulse 2.4s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%,
    100% {
      transform: scaleY(1);
      transform-origin: top;
      opacity: 0.6;
    }
    50% {
      transform: scaleY(1.4);
      transform-origin: top;
      opacity: 1;
    }
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero__services,
    .hero__scroll {
      display: none;
    }

    .hero__content {
      padding-top: clamp(2rem, 6vh, 4rem);
      max-width: 100%;
    }

    .hero__nav ul {
      gap: 1.25rem;
    }
  }

  @media (max-width: 640px) {
    .hero__header {
      padding: 1rem 1.25rem;
    }

    .hero__nav a {
      font-size: 0.9rem;
    }

    .hero__content {
      padding: 2rem 1.25rem 0;
    }

    .hero__title {
      font-size: clamp(3rem, 14vw, 5rem);
    }

    .hero__cta {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__video {
      display: none;
    }
    .hero__scroll-line {
      animation: none;
    }
    .btn {
      transition: none;
    }
  }
</style>
